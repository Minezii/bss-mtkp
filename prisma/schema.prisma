generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id        Int      @id @default(autoincrement())
  checkId   String?  @unique @default(uuid())
  type      String   // material, teacher, tool
  title     String
  author    String?
  group     String?  // New field for groups like "ТИП 11"
  content   String?  // description, link or review text
  fileUrl   String?
  imageUrl  String?  // Photo for teachers or rich content
  status    String   @default("pending") // pending, approved, rejected, draft
  createdAt DateTime @default(now())
}

model Material {
  id        Int      @id @default(autoincrement())
  title     String
  group     String?  // New field
  course    Int
  category  String   // Конспект, Лекция, Шпаргалка
  subject   String
  downloads Int      @default(0)
  fileUrl   String?
  createdAt DateTime @default(now())
}

model Teacher {
  id             Int      @id @default(autoincrement())
  name           String
  imageUrl       String?  // Photo of the teacher
  department     String
  subjects       String   // Comma-separated list
  lecturesRating Float    @default(0)
  examsRating    Float    @default(0)
  clarityRating  Float    @default(0)
  fairnessRating Float    @default(0)
  overallRating  Float    @default(0)
  reviewsCount   Int      @default(0)
  reviews        Review[]
  createdAt      DateTime @default(now())
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  group        String?  // New field for groups like "ТИП 11"
  reviews      Review[]
  createdAt    DateTime @default(now())
}

model Review {
  id             Int      @id @default(autoincrement())
  userId         Int
  teacherId      Int
  content        String?
  rating         Int      @default(0) // Overall average of 1-5
  lecturesRating Int      @default(0)
  examsRating    Int      @default(0)
  clarityRating  Int      @default(0)
  fairnessRating Int      @default(0)
  isRecommended  Boolean  @default(true)
  user           User     @relation(fields: [userId], references: [id])
  teacher        Teacher  @relation(fields: [teacherId], references: [id])
  createdAt      DateTime @default(now())

  @@unique([userId, teacherId])
}

model Tool {
  id        Int      @id @default(autoincrement())
  name      String
  desc      String
  category  String
  url       String?
  createdAt DateTime @default(now())
}

model Subject {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}
